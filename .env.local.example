# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose to browser

# ─── Upstash Redis (BullMQ job queue) ─────────────────────────────────────────
# Get from: console.upstash.com → Redis → your-db → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── Dodo Payments ────────────────────────────────────────────────────────────
# Get from: app.dodopayments.com → Settings → API Keys
DODO_PAYMENTS_API_KEY=your-dodo-api-key
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret
DODO_ENV=test_mode   # Change to live_mode for production

# ─── PostHog (analytics + session recording) ──────────────────────────────────
# Get from: app.posthog.com → Project → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
